// Deck del Taller 3, sin formato de marca. Estilo neutro, pendiente de diseno.
const pptxgen = require("pptxgenjs");
const pres = new pptxgen();
pres.layout = "LAYOUT_WIDE"; // 13.3 x 7.5
pres.author = "Walter E. Calcagno";
pres.title = "Taller 3: IA Avanzada";

const TITLE = { x: 0.7, y: 0.5, w: 11.9, h: 0.9, fontSize: 30, bold: true, fontFace: "Calibri", color: "000000" };
const BODY = { x: 0.7, y: 1.6, w: 11.9, h: 5.2, fontSize: 17, fontFace: "Calibri", color: "000000", valign: "top" };
const TBL = { x: 0.7, y: 1.6, w: 11.9, fontSize: 13, fontFace: "Calibri", color: "000000",
  border: { pt: 0.5, color: "999999" }, valign: "middle" };
const HDR = { bold: true, fill: { color: "E6E6E6" } };

function bullets(items) {
  return items.map((t, i) => ({
    text: t,
    options: { bullet: true, breakLine: i !== items.length - 1, paraSpaceAfter: 8 },
  }));
}

function slide(title, body, notes) {
  const s = pres.addSlide();
  s.addText(title, { ...TITLE });
  if (Array.isArray(body)) s.addText(bullets(body), { ...BODY });
  else if (typeof body === "string") s.addText(body, { ...BODY, fontSize: 18 });
  if (notes) s.addNotes(notes);
  return s;
}

function tableSlide(title, rows, colW, notes) {
  const s = pres.addSlide();
  s.addText(title, { ...TITLE });
  const data = rows.map((r, i) => r.map((c) => (i === 0 ? { text: c, options: HDR } : { text: c })));
  s.addTable(data, { ...TBL, colW });
  if (notes) s.addNotes(notes);
  return s;
}

