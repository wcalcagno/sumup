s1.addText("Langdock. 2 horas. 10 de julio de 2026", { x: 0.7, y: 3.4, w: 11.9, h: 0.5, fontSize: 20, fontFace: "Calibri", color: "000000" });
s1.addText("Walter E. Calcagno, Microsoft MVP Data Platform", { x: 0.7, y: 4.0, w: 11.9, h: 0.5, fontSize: 16, fontFace: "Calibri", color: "404040" });
