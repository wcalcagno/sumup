  " |\n" +
  "[6] Condition\n" +
  "     |-- A: aprobar y total <= 100.000  -> notificar\n" +
  "     |-- B: escalar, o total > 100.000  -> Human in the Loop\n" +
  "     `-- C: rechazar, guardrail fallido, o contradiccion -> notificar motivo",
  { x: 0.7, y: 1.6, w: 11.9, h: 5.0, fontSize: 14, fontFace: "Consolas", color: "000000", valign: "top" });
s18.addNotes("El orden de las ramas importa. La rama C se evalua primero. Un flujo que evalua la aprobacion primero, aprueba antes de mirar la contradiccion.");

